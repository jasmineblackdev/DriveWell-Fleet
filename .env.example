# DriveWell Fleet Dashboard — environment variables
#
# Copy this file to .env and fill in values for your environment.
# Leave VITE_API_URL blank (or remove it) to run entirely on mock fleet data.

# URL of the shared DriveWell API server.
# Example (local dev):  http://localhost:4000
# Example (production): https://api.drivewell.app
VITE_API_URL=
